# Twitch — get from https://dev.twitch.tv/console/apps (register an app, copy client id/secret; broadcaster id via Twitch API users endpoint; webhook secret is a random string you generate)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BROADCASTER_ID=
TWITCH_WEBHOOK_SECRET=

# Discord — get from https://discord.com/developers/applications (create application, add bot, copy token; channel id from Discord client with developer mode on)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# YouTube — Google Cloud Console project, YouTube Data API v3 enabled, OAuth
# consent screen (External, youtube.upload scope, add the uploading account as
# a test user), then Credentials -> Create OAuth client ID -> Desktop app.
# YOUTUBE_REFRESH_TOKEN is captured by running scripts/youtube-login.js once.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Server
PORT=3000
LOG_LEVEL=info

# Optional — separate Discord webhook URL for crash/error alerts (no-op if unset)
DISCORD_ERROR_WEBHOOK_URL=

# The vision combat filter (config.js detector.combatFilter) runs against a
# local Ollama instance — no env var needed. Requires `ollama pull gemma3:4b`
# (or whatever model config.js points at) on the runtime machine; if Ollama
# isn't reachable, filtering is skipped and all highlights pass through.
